# Copy this file to `.env` and fill in real values.
# NEVER commit `.env`. Secrets are read only via os.environ.get(...).

# Hugging Face access token (for gated/large model downloads).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: only needed if running real API cost-reference calls.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx
